      "source": [
        "import matplotlib.pyplot as plt\n",
        "import random\n",
        "\n",
        "class Customer:\n",
        "  def __init__(self, name, subscription, tuns, subscribed):\n",
        "    self.name = name\n",
        "    self.subscription = subscription\n",
        "    self.tuns = tuns\n",
        "    self.subscribed = subscribed\n",
        "\n",
        "l = []\n",
        "a = int(input(\"Enter values:\"))\n",
        "\n",
        "for i in range(a):\n",
        "  l.append(Customer(\n",
        "      name=random.randint(1,a**10),\n",
        "      subscription=random.randint(1,3),\n",
        "      tuns=random.randint(1,120),\n",
        "      subscribed=random.randint(0,1)\n",
        "  ))\n",
        "\n",
        "print(\"NAME    SUBSCRIPTION LEVEL T.U.N.S. SUBSCRIBED\\n\")\n",
        "\n",
        "for i in l:\n",
        "  print(i.name, i.subscription, i.tuns, \"days\", i.subscribed)\n",
        "\n",
        "subscribed_customers = [i for i in l if i.subscribed == 1]\n",
        "churned_customers = [i for i in l if i.subscribed == 0]\n",
        "\n",
        "print(\"\\nSubscribed customers:\")\n",
        "for i in subscribed_customers:\n",
        "  print(i.name, i.subscription, i.tuns, \"days\", i.subscribed)\n",
        "\n",
        "print(\"\\nChurned customers:\")\n",
        "for i in churned_customers:\n",
        "  if (i.subscription == 1 and i.tuns < 10) or \\\n",
        "     (i.subscription == 2 and i.tuns < 20) or \\\n",
        "     (i.subscription == 3 and i.tuns < 30):\n",
        "    print(i.name, i.subscription, i.tuns, \"days\", i.subscribed)\n",
        "\n",
        "# Plot\n",
        "for i in l:\n",
        "  plt.scatter(i.tuns, i.subscription)\n",
        "\n",
        "plt.xlabel(\"T.U.N.S (days)\")\n",
        "plt.ylabel(\"Subscription Level\")\n",
        "plt.title(\"Customer Usage vs Subscription\")\n",
        "plt.show()"
      ]
